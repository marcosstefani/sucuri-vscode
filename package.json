{
  "name": "sucuri",
  "displayName": "Sucuri",
  "description": "Basic language support for Sucuri template engine",
  "version": "1.0.0",
  "publisher": "marcosstefani",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcosstefani/sucuri-vscode.git"
  },
  "homepage": "https://github.com/marcosstefani/sucuri",
  "author": {
    "name": "Marcos Stefani Rosa",
    "email": "marcos.cantor@gmail.com"
  },
  "license": "BSD-3-Clause",
  "icon": "icon.png",
  "scripts": {
    "test": "vscode-tmgrammar-test \"tests/**/*.suc\"",
    "test:update": "vscode-tmgrammar-test --update \"tests/**/*.suc\""
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sucuri",
        "aliases": [
          "Sucuri",
          "sucuri"
        ],
        "extensions": [
          ".suc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sucuri",
        "scopeName": "source.sucuri",
        "path": "./syntaxes/sucuri.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sucuri",
        "path": "./snippets/sucuri.json"
      }
    ]
  },
  "devDependencies": {
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
